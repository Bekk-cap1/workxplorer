generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ZoneType {
  INDOOR
  OUTDOOR
  VIP
}

enum TableType {
  STANDARD
  VIP
  FAMILY
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum ReservationStatus {
  PENDING_PAYMENT
  CONFIRMED
  COMPLETED
  CANCELLED_BY_USER
  CANCELLED_BY_RESTAURANT
  NO_SHOW
}

enum DepositStatus {
  NONE
  PENDING
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FORFEITED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum UserRole {
  CUSTOMER
  ADMIN
}

model Branch {
  id           String         @id @default(uuid())
  name         String
  address      String
  lat          Float?
  lng          Float?
  workHours    Json?          @map("work_hours")
  isActive     Boolean        @default(true) @map("is_active")
  zones        Zone[]
  reservations Reservation[]
  menuItems    MenuItem[]
  reviews      Review[]
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@map("branches")
}

model Review {
  id            String       @id @default(uuid())
  branchId      String       @map("branch_id")
  branch        Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  userId        String       @map("user_id")
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservationId String?      @unique @map("reservation_id")
  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  rating        Int
  comment       String?      @db.Text
  isPublished   Boolean      @default(true) @map("is_published")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@index([branchId, isPublished])
  @@map("reviews")
}

model MenuItem {
  id          String   @id @default(uuid())
  branchId    String   @map("branch_id")
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  category    String   @default("Asosiy")
  price       Decimal  @db.Decimal(12, 2)
  imageUrl    String?  @map("image_url") @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  reservationItems ReservationItem[]

  @@index([branchId, isActive, sortOrder])
  @@map("menu_items")
}

model ReservationItem {
  id            String      @id @default(uuid())
  reservationId String      @map("reservation_id")
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  menuItemId    String      @map("menu_item_id")
  menuItem      MenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  name          String
  unitPrice     Decimal     @map("unit_price") @db.Decimal(12, 2)
  quantity      Int         @default(1)
  notes         String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([reservationId])
  @@map("reservation_items")
}

model Zone {
  id           String            @id @default(uuid())
  branchId     String            @map("branch_id")
  branch       Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name         String
  type         ZoneType
  floor        Int?
  floorPlanSvg String?           @map("floor_plan_svg") @db.Text
  isSeasonal   Boolean           @default(false) @map("is_seasonal")
  activeFrom   DateTime?         @map("active_from")
  activeTo     DateTime?         @map("active_to")
  tables       RestaurantTable[]

  @@map("zones")
}

model RestaurantTable {
  id           String          @id @default(uuid())
  zoneId       String          @map("zone_id")
  zone         Zone            @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  number       String
  seats        Int
  type         TableType       @default(STANDARD)
  shape        String?
  xPos         Float           @map("x_pos")
  yPos         Float           @map("y_pos")
  status       TableStatus     @default(AVAILABLE)
  isCombinable Boolean         @default(false) @map("is_combinable")
  reservations Reservation[]

  @@unique([zoneId, number], map: "tables_zone_number_unique")
  @@map("tables")
}

model User {
  id                  String    @id @default(uuid())
  phone               String    @unique
  name                String?
  role                UserRole  @default(CUSTOMER)
  smsVerified         Boolean   @default(false) @map("sms_verified")
  pushToken           String?   @map("push_token")
  noShowStreak        Int       @default(0) @map("no_show_streak")
  bookingBlockedUntil DateTime? @map("booking_blocked_until")
  telegramId          String?   @unique @map("telegram_id")
  telegramChatId      String?   @map("telegram_chat_id")
  telegramUsername    String?   @map("telegram_username")
  telegramFirstName   String?   @map("telegram_first_name")
  telegramLinkedAt    DateTime? @map("telegram_linked_at")
  completedBookings   Int       @default(0) @map("completed_bookings")
  loyaltyBonuses      Int       @default(0) @map("loyalty_bonuses")
  createdAt           DateTime  @default(now()) @map("created_at")
  reservations        Reservation[]
  payments            Payment[]
  reviews             Review[]

  @@map("users")
}

model Reservation {
  id            String            @id @default(uuid())
  userId        String            @map("user_id")
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tableId       String            @map("table_id")
  table         RestaurantTable   @relation(fields: [tableId], references: [id], onDelete: Cascade)
  branchId      String            @map("branch_id")
  branch        Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  startAt       DateTime          @map("start_at")
  endAt         DateTime          @map("end_at")
  guestsCount   Int               @map("guests_count")
  status        ReservationStatus @default(PENDING_PAYMENT)
  depositAmount Decimal           @map("deposit_amount") @db.Decimal(12, 2)
  depositStatus DepositStatus     @default(NONE) @map("deposit_status")
  holdExpiresAt DateTime?         @map("hold_expires_at")
  payments      Payment[]
  preorderItems ReservationItem[]
  review        Review?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@index([branchId, startAt])
  @@index([tableId, startAt])
  @@map("reservations")
}

model Payment {
  id             String        @id @default(uuid())
  reservationId  String        @map("reservation_id")
  reservation    Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  userId         String        @map("user_id")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount         Decimal       @db.Decimal(12, 2)
  method         String
  provider       String?
  checkoutUrl    String?       @map("checkout_url") @db.Text
  status         PaymentStatus @default(PENDING)
  transactionId  String?       @map("transaction_id")
  refundAmount   Decimal?      @map("refund_amount") @db.Decimal(12, 2)
  refundDate     DateTime?     @map("refund_date")
  createdAt      DateTime      @default(now()) @map("created_at")

  @@map("payments")
}
