# Если у вас на 5432 уже есть локальный PostgreSQL — в docker-compose.yml публикуется 5433:5432
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/beshqozon?schema=public"
PORT=4000
JWT_SECRET="o‘zgartiring-uzun-random"
# Bir yoki vergul bilan: https://app.uz,https://admin.uz
WEB_ORIGIN="http://localhost:3000"

# Production: Swagger o‘chiq; kerak bo‘lsa true
# ENABLE_SWAGGER="false"

# API to‘g‘ridan-to‘g‘ri HTTPS bilan ishlayotganda (aks holda o‘chiq qoldiring)
# ENABLE_API_HSTS="true"

# Nginx/proxy orqasida real IP uchun (odatda 1)
# TRUST_PROXY_HOPS="1"

REDIS_URL="redis://127.0.0.1:6379"

# Dev: SMS o‘rniga doimiy kod
DEV_OTP="123456"

# Dev: admin JWT (faqat lokal)
ALLOW_DEV_ADMIN="true"

# Admin panel login va parol (POST /api/auth/admin-login)
ADMIN_LOGIN="admin"
ADMIN_PASSWORD="admin123"

# Eskiz.uz SMS (https://notify.eskiz.uz)
ESKIZ_EMAIL=""
ESKIZ_PASSWORD=""
ESKIZ_FROM="4546"

# Payme checkout + merchant JSON-RPC (/api/integrations/payme)
PAYME_MERCHANT_ID=""
PAYME_MERCHANT_KEY=""
PAYME_RETURN_URL="http://localhost:3000/bron"
PAYME_SKIP_AUTH="true"

# Click redirect (/api/integrations/click/complete)
CLICK_SERVICE_ID=""
CLICK_MERCHANT_ID=""
CLICK_SECRET_KEY=""
CLICK_MERCHANT_USER_ID="1"
CLICK_RETURN_URL="http://localhost:3000/bron"
CLICK_SKIP_SIGN="true"

# Telegram bot
# Как получить: @BotFather → /newbot → имя → username (напр. BeshqozonBot) → токен
TELEGRAM_ENABLED="false"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME="BeshqozonBot"
